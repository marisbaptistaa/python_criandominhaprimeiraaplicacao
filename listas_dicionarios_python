# utilizar bibliotecas = import

import os

# restaurantes = ['Sushi', 'Feijoada']  # listas | criando listas de restaurantes
# forçando dados, porque ainda não vamos trabalhar com o banco de dados.

restaurantes = [{'nome': 'Sushi', 'categoria': 'Japonesa', 'ativo': False},
                {'nome': 'Foijoada', 'categoria': 'Mineira', 'ativo': True}]
# dicionario = chave e valor


def exibir_nome_do_programa():
    print('🅢🅐🅑🅞🅡 🅔🅧🅟🅡🅔🅢🅢\n')  # print = exibir informação no terminal


def exibir_opcoes():
    print('1. Cadastrar restaurante')  # print = exibir informação no terminal
    print('2. Listar restaurante')  # print = exibir informação no terminal
    print('3. Alternar restaurante')  # print = exibir informação no terminal
    print('4. Sair\n')  # print = exibir informação no terminal | \n = pular linha


def finalizar_app():
    exibir_subtitulo('Finalizar app')


def voltar_ao_menu_principal():
    input('\nDigite uma tecla para voltar ao menu')
    main()

# criando essa função para usuários que não vão inserir opções de 1 a 4.


def opcao_invalida():
    print('Opção inválida!\n')
    voltar_ao_menu_principal()


def exibir_subtitulo(texto):
    os.system('cls')
    linha = '*' * (len(texto))  # variável
    print(linha)
    print(texto)
    print(linha)
    print()


def cadastrar_novo_restaurante():
    exibir_subtitulo('Cadastro de novos restaurantes')
    nome_do_restaurante = input(
        'Digite o nome do restaurante que deseja cadastrar: ')
    # para colocar na lista, utiliza a palavra append
    categoria = input(f'Digite o nome da categoria {nome_do_restaurante}: ')
    dados_do_restaurante = {'nome': nome_do_restaurante,
                            'categoria': categoria, 'ativo': False}

    restaurantes.append(dados_do_restaurante)
    print(f'O restaurante {nome_do_restaurante} foi cadastrado com sucesso!\n')
    voltar_ao_menu_principal()


def listar_restaurantes():
    exibir_subtitulo('Listando restaurantes')

    print(f'{'Nome do restaurante'.ljust(22)} | {'Categoria'.ljust(20)} | {'status'}')
    for restaurante in restaurantes:  # loop for
        nome_restaurante = restaurante['nome']
        categoria = restaurante['categoria']
        # ternário: o que for verdadeiro se a segunda condição for verdadeira
        ativo = 'ativado' if restaurante['ativo'] else 'desativado'
        print(f'- {nome_restaurante.ljust(20)} | {categoria.ljust(20)} | {ativo}')

    voltar_ao_menu_principal()


def alternar_estado_restaurante():
    exibir_subtitulo('Alternando estado do restaurante')
    nome_restaurante = input(
        'Digite o nome do restaurante que deseja alternar o estado: ')
    restaurante_encontrado = False

    for restaurante in restaurantes:
        if nome_restaurante == restaurante['nome']:
            restaurante_encontrado = True
            restaurante['ativo'] = not restaurante['ativo']
            mensagem = f'O restaurante {nome_restaurante} foi ativado com sucesso' if restaurante[
                'ativo'] else f'O restaurante {nome_restaurante} foi desativado com sucesso'
            # ternário
            print(mensagem)
    if not restaurante_encontrado:
        print('O restaurante não foi encontrado')

    voltar_ao_menu_principal()


def escolher_opcao():
    try:  # tentar rodar essa opção, se não, rodar a função em except.
        opcao_escolhida = int(input('Escolha uma opção: ')
                              )  # convertendo para inteiro
        print(f'Você escolheu a opção {opcao_escolhida}')

        if opcao_escolhida == 1:  # caso a opção escolhida seja = 1
            cadastrar_novo_restaurante()
        elif opcao_escolhida == 2:  # caso a opção escolhida for = 2
            listar_restaurantes()
        elif opcao_escolhida == 3:  # caso a opção escolhida for = 1
            alternar_estado_restaurante()
        elif opcao_escolhida == 4:  # caso a opção escolhida for = 1
            finalizar_app()  # utilizando função
        else:
            opcao_invalida()  # utilizando função
    except:
        opcao_invalida()


def main():  # função
    os.system('cls')
    exibir_nome_do_programa()
    exibir_opcoes()
    escolher_opcao()


if __name__ == '__main__':
    main()

